# Database Connection URL (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gasmon

# Relayer Wallet Private Key (Server-only, do NOT prefix with NEXT_PUBLIC_)
# This wallet needs a small amount of MON to pay transaction gas fees
RELAYER_PRIVATE_KEY=0x_YOUR_RELAYER_PRIVATE_KEY

# Deployed Smart Contract Address (GasVault)
NEXT_PUBLIC_GAS_VAULT_ADDRESS=0x_GAS_VAULT_CONTRACT_ADDRESS

# Monad Testnet RPC URL (Optional, defaults to https://testnet-rpc.monad.xyz)
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
